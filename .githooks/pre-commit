#
# pre-commit — Layer 1 of the rust/shekyl-oxide divergence defense.
#
# Opt in once per clone:
#     git config core.hooksPath .githooks
#
# This hook short-circuits when no staged change touches rust/shekyl-oxide/.
# When it does fire, exit codes propagate from check_oxide_divergence.sh:
#   0 — vendored tree is byte-equal to the pinned fork commit (commit allowed)
#   1 — divergence detected (commit blocked)
#   2 — infra error (commit allowed; CI will re-check)
#
# Why exit 2 ⇒ commit allowed: pre-commit runs offline-by-default. If the
# fork clone fails because the developer is on a plane, blocking the commit
# is hostile and trains people to bypass the hook with --no-verify, which
# defeats the whole point. CI runs the same check with retries; let CI do
# the blocking. The console message is loud enough to catch attention.

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$REPO_ROOT" ]; then
  exit 0
fi

cd "$REPO_ROOT"

# Fast-path: skip if no staged change touches rust/shekyl-oxide/.
if ! git diff --cached --name-only -- rust/shekyl-oxide | grep -q .; then
  exit 0
fi

if [ ! -x scripts/ci/check_oxide_divergence.sh ]; then
  echo "[pre-commit] scripts/ci/check_oxide_divergence.sh missing or not executable; skipping"
  exit 0
fi

# Cache between local invocations so repeated commits don't re-clone.
export OXIDE_FORK_CACHE_DIR="${OXIDE_FORK_CACHE_DIR:-$HOME/.cache/shekyl-oxide-fork}"

scripts/ci/check_oxide_divergence.sh
rc=$?

case "$rc" in
  0)
    exit 0
    ;;
  1)
    echo
    echo "[pre-commit] BLOCKED: rust/shekyl-oxide/ diverges from the pinned fork commit."
    echo "[pre-commit] Either re-sync (Step 2 of the vendored-oxide remediation plan) or"
    echo "[pre-commit] bump UPSTREAM_MONERO_OXIDE_COMMIT after promoting the change upstream."
    echo "[pre-commit] If you must commit unsynced (e.g. WIP on the sync itself), run:"
    echo "[pre-commit]     git commit --no-verify"
    exit 1
    ;;
  *)
    echo
    echo "[pre-commit] WARN: divergence check could not complete (exit $rc, infra)."
    echo "[pre-commit] Allowing commit — CI will re-check with retries."
    exit 0
    ;;
esac
