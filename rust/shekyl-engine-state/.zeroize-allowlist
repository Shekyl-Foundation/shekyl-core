rust/shekyl-wallet-state/src/tx_meta_block.rs|pub tx_keys: BTreeMap<[u8; 32], TxSecretKeys>
rust/shekyl-wallet-state/src/tx_meta_block.rs|pub tx_notes: BTreeMap<[u8; 32], String>
