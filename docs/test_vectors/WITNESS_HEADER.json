{
  "description": "Locked test vectors for FCMP++ witness header round-trip. The 256-byte header layout is [O:32][I:32][C:32][h_pqc:32][x:32][y:32][z:32][a:32]. C++ writes via shekyl_fcmp_build_witness_header, Rust parses via parse_prove_witness. Any change to this file is a consensus change.",
  "header_size_bytes": 256,
  "field_layout": [
    {"name": "output_key",      "offset": 0,   "size": 32, "description": "O: output public key"},
    {"name": "key_image_gen",   "offset": 32,  "size": 32, "description": "I: key image generator Hp(O)"},
    {"name": "commitment",      "offset": 64,  "size": 32, "description": "C: Pedersen commitment"},
    {"name": "h_pqc",           "offset": 96,  "size": 32, "description": "H(hybrid_public_key): PQC leaf scalar"},
    {"name": "spend_key_x",     "offset": 128, "size": 32, "description": "x: SAL spend secret (DL w.r.t. G)"},
    {"name": "spend_key_y",     "offset": 160, "size": 32, "description": "y: SAL T-component secret"},
    {"name": "commitment_mask", "offset": 192, "size": 32, "description": "z: Pedersen commitment mask"},
    {"name": "pseudo_out_blind","offset": 224, "size": 32, "description": "a: pseudo-out blinding factor"}
  ],
